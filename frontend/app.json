{
  "expo": {
    "name": "BRAPRO",
    "slug": "brapro",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/bradatec.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/bradatec.png",
      "resizeMode": "contain",
      "backgroundColor": "#2563eb"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bradatec.brapro"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/bradatec.png",
        "backgroundColor": "#2563eb"
      },
      "package": "com.bradatec.brapro",
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "La app necesita acceso a tus fotos para agregar imágenes a las proformas."
        }
      ]
    ],
    "owner": "colom",
    "extra": {
      "eas": {
        "projectId": "4c386bf0-099b-456b-b39d-81f424fe908f"
      }
    }
  }
}
